# DataSec Hub 环境变量配置

# API基础URL (后端服务地址)
VITE_API_BASE_URL=http://localhost:3000

# 使用Mock API (true=使用mock数据, false=使用真实后端API)
VITE_USE_MOCK_API=true

# 注意：
# 1. 开发时如果后端未启动，设置 VITE_USE_MOCK_API=true 使用mock数据
# 2. 需要连接真实后端时，设置 VITE_USE_MOCK_API=false
# 3. 复制此文件为 .env.local 并修改值，.env.local 不会被提交到git
