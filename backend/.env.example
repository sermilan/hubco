# Application
NODE_ENV=development
PORT=3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=datasec_hub
DB_SSL=false

# Elasticsearch
ELASTICSEARCH_NODE=http://localhost:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=datasec:

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_REFRESH_EXPIRES_IN=30d

# ============================================
# AI 服务配置
# ============================================

# 主AI Provider (zhipu, deepseek, kimi, baidu, aliyun, doubao, mock)
AI_PROVIDER=mock

# AI请求超时时间（毫秒）
AI_TIMEOUT=60000

# Fallback链（逗号分隔，按优先级）
AI_FALLBACK_CHAIN=zhipu,deepseek,kimi,aliyun,baidu,mock

# 智谱AI (GLM-4) - 推荐首选
ZHIPU_API_KEY=your-zhipu-api-key
ZHIPU_MODEL=glm-4-flash

# DeepSeek
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-chat

# 月之暗面 Kimi
KIMI_API_KEY=your-kimi-api-key
KIMI_MODEL=moonshot-v1-8k

# 百度千帆 (文心一言)
BAIDU_API_KEY=your-baidu-api-key
BAIDU_API_SECRET=your-baidu-api-secret
BAIDU_MODEL=ernie-bot-4

# 阿里云通义千问
ALIYUN_API_KEY=your-aliyun-api-key
ALIYUN_MODEL=qwen-turbo

# 字节豆包
DOUBAO_API_KEY=your-doubao-api-key
DOUBAO_MODEL=doubao-pro-32k
